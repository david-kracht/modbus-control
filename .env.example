# Path to the devices configuration YAML file
MODBUS_DEVICES_YAML=devices.yaml

# Control Center Backend Settings
CTRL_CENTER_HOST=0.0.0.0
CTRL_CENTER_PORT=8000

# Modbus Simulator Settings
SIM_HOST=0.0.0.0
SIM_PORT=5020
SIM_SCHEMA=v10

# Default Ad-Hoc / Anonymous Modbus Connection Defaults
# (Uncomment and set these if you want to run CLI commands against a single default device without devices.yaml)
# DEFAULT_MODBUS_HOST=127.0.0.1
# DEFAULT_MODBUS_PORT=5020
# DEFAULT_MODBUS_UNIT_ID=1
# DEFAULT_MODBUS_SCHEMA=v10

# Independent Frontend Client Settings
# (Only needed if hosting/running the React frontend on a separate server/origin than the backend API, e.g. Vite dev server)
# VITE_API_URL=http://127.0.0.1:8000
# VITE_WS_URL=ws://127.0.0.1:8000

# Customization & Branding Settings
SUITE_TITLE="Modbus Control Suite"
# SUITE_LOGO_PATH=""
